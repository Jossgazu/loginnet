@model LoginNet.Models.Usuario
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Perfil de Usuario - CEPLAN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --color-primary: #8B1D1D;
            --color-secondary: #1D70B8;
            --color-warning: #D97706;
            --color-success: #059669;
            --color-light: #F3F4F6;
            --color-dark: #1F2937;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--color-light);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        .header-bar {
            background-color: var(--color-primary);
            padding: 12px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .header-logo {
            color: white;
            font-weight: bold;
            font-size: 1.2rem;
        }
        
        .header-right {
            display: flex;
            align-items: center;
            gap: 20px;
            color: white;
        }
        
        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: rgba(255,255,255,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .help-icon, .logout-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: rgba(255,255,255,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-decoration: none;
            transition: background-color 0.3s;
            cursor: pointer;
            border: none;
        }
        
        .help-icon:hover, .logout-icon:hover {
            background-color: rgba(255,255,255,0.4);
            color: white;
        }
        
        .main-content {
            flex: 1;
            padding: 30px;
        }
        
        .profile-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            overflow: hidden;
            max-width: 900px;
            margin: 0 auto;
        }
        
        .profile-header {
            background: linear-gradient(135deg, var(--color-primary) 0%, #6B1520 100%);
            padding: 30px;
            color: white;
            display: flex;
            align-items: center;
            gap: 25px;
        }
        
        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background-color: rgba(255,255,255,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
        }
        
        .profile-name {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 5px;
        }
        
        .profile-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--color-success);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
        }
        
        .profile-body {
            padding: 30px;
        }
        
        .info-section {
            margin-bottom: 25px;
        }
        
        .info-section-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--color-dark);
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--color-light);
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }
        
        .info-item {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        
        .info-label {
            font-size: 0.85rem;
            color: #6B7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .info-value {
            font-size: 1rem;
            color: var(--color-dark);
            font-weight: 500;
        }
        
        .nav-tabs {
            border-bottom: 2px solid var(--color-light);
            margin-bottom: 25px;
        }
        
        .nav-tabs .nav-link {
            border: none;
            color: #6B7280;
            font-weight: 500;
            padding: 12px 20px;
        }
        
        .nav-tabs .nav-link.active {
            color: var(--color-secondary);
            border-bottom: 3px solid var(--color-secondary);
            background: transparent;
        }
        
        .footer-bar {
            background: linear-gradient(to right, var(--color-primary) 33.33%, var(--color-dark) 33.33%, var(--color-dark) 66.66%, #6B7280 66.66%);
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .footer-logo {
            color: white;
            font-weight: bold;
            font-size: 0.85rem;
        }
        
        .session-warning-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }
        
        .session-warning-modal.show {
            display: flex;
        }
        
        .session-warning-content {
            background: white;
            border-radius: 12px;
            padding: 30px;
            max-width: 400px;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        
        .warning-icon {
            width: 60px;
            height: 60px;
            background: #FEF3C7;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }
        
        .warning-icon i {
            font-size: 1.8rem;
            color: var(--color-warning);
        }
        
        .btn-extender {
            background: var(--color-warning);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 8px;
            font-weight: 600;
            width: 100%;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        
        .btn-extender:hover {
            background: #B45309;
            color: white;
        }
    </style>
</head>
<body>
    <header class="header-bar">
        <div class="header-logo">CEPLAN</div>
        <div class="header-right">
            <a href="#" class="help-icon" title="Ayuda">
                <i class="bi bi-question-lg"></i>
            </a>
            <div class="user-info">
                <div class="user-avatar">
                    <i class="bi bi-person"></i>
                </div>
                <span>@Model.Nombre</span>
            </div>
            <form asp-action="CerrarSesion" method="post" style="display: inline;">
                <button type="submit" class="logout-icon" title="Cerrar sesión">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        </div>
    </header>
    
    <main class="main-content">
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div>
                    <div class="profile-name">@Model.Nombre</div>
                    <div class="profile-status">
                        <i class="bi bi-check-circle-fill"></i>
                        Activo
                    </div>
                </div>
            </div>
            
            <div class="profile-body">
                <ul class="nav nav-tabs" id="profileTabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#infoBasica">Información básica</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#responsabilidades">Responsabilidades</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#historial">Historial</a>
                    </li>
                </ul>
                
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="infoBasica">
                        <div class="info-section">
                            <div class="info-section-title">Datos Personales</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <span class="info-label">Tipo de Documento</span>
                                    <span class="info-value">@Model.TipoDocumento</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Número de Documento</span>
                                    <span class="info-value">@Model.NumeroDocumento</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Nombres</span>
                                    <span class="info-value">@Model.Nombre</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Correo Electrónico</span>
                                    <span class="info-value">@Model.Correo</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="tab-pane fade" id="responsabilidades">
                        <div class="info-section">
                            <div class="info-section-title">Roles y Permisos</div>
                            <p class="text-muted">No hay responsabilidades asignadas.</p>
                        </div>
                    </div>
                    
                    <div class="tab-pane fade" id="historial">
                        <div class="info-section">
                            <div class="info-section-title">Historial de Actividad</div>
                            <p class="text-muted">No hay actividad reciente.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    
    <footer class="footer-bar">
        <div class="footer-logo">PERÚ | Presidencia del Consejo de Ministros</div>
        <div class="footer-logo">Centro Nacional de Planeamiento Estratégico</div>
    </footer>
    
    <div class="session-warning-modal" id="sessionWarningModal">
        <div class="session-warning-content">
            <div class="warning-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h4>Su sesión está a punto de expirar</h4>
            <p class="text-muted mb-4">
                Por seguridad, su sesión expirará en <strong id="countdownSeconds">49</strong> segundos.
            </p>
            <button type="button" class="btn-extender" id="btnExtenderSesion">
                <i class="bi bi-arrow-clockwise me-2"></i>Extender sesión
            </button>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let countdown = 49;
        let warningShown = false;
        
        function verificarSesion() {
            fetch('@Url.Action("VerificarSesion", "Account")')
                .then(response => response.json())
                .then(data => {
                    if (data.expirada) {
                        window.location.href = '@Url.Action("CerrarSesion", "Account")';
                    } else if (data.mostrarWarning && !warningShown) {
                        warningShown = true;
                        countdown = data.segundosRestantes;
                        document.getElementById('sessionWarningModal').classList.add('show');
                        iniciarCountdown();
                    }
                });
        }
        
        function iniciarCountdown() {
            const countdownEl = document.getElementById('countdownSeconds');
            const interval = setInterval(() => {
                countdown--;
                countdownEl.textContent = countdown;
                
                if (countdown <= 0) {
                    clearInterval(interval);
                    window.location.href = '@Url.Action("CerrarSesion", "Account")';
                }
            }, 1000);
            
            document.getElementById('btnExtenderSesion').onclick = function() {
                clearInterval(interval);
                fetch('@Url.Action("ExtenderSesion", "Account")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('sessionWarningModal').classList.remove('show');
                        warningShown = false;
                        countdown = 49;
                    }
                });
            };
        }
        
        setInterval(verificarSesion, 5000);
    </script>
</body>
</html>
